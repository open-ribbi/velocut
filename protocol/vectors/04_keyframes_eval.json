{
  "name": "keyframe interpolation: linear, hold, symmetric bezier",
  "steps": [
    {"apply": {"type":"addAsset","id":"a1","kind":"video","src":"mem://a1","name":"A","durationUs":10000000}},
    {"apply": {"type":"addTrack","kind":"video"}},
    {"apply": {"type":"addClip","trackId":"track_1","assetId":"a1","startUs":0,"durationUs":4000000}},
    {"apply": {"type":"setKeyframe","clipId":"clip_2","property":"opacity","keyframe":{"timeUs":0,"value":0.0,"easing":{"kind":"linear"}}}},
    {"apply": {"type":"setKeyframe","clipId":"clip_2","property":"opacity","keyframe":{"timeUs":2000000,"value":1.0,"easing":{"kind":"hold"}}}},
    {"apply": {"type":"setKeyframe","clipId":"clip_2","property":"opacity","keyframe":{"timeUs":4000000,"value":0.0,"easing":{"kind":"linear"}}}},
    {"apply": {"type":"setKeyframe","clipId":"clip_2","property":"x","keyframe":{"timeUs":0,"value":0.0,"easing":{"kind":"bezier","x1":0.5,"y1":0.0,"x2":0.5,"y2":1.0}}}},
    {"apply": {"type":"setKeyframe","clipId":"clip_2","property":"x","keyframe":{"timeUs":2000000,"value":100.0,"easing":{"kind":"linear"}}}}
  ],
  "expect": {
    "eval": [
      {"timeUs":1000000,"layers":[{"clipId":"clip_2","opacity":0.5,"x":50.0}]},
      {"timeUs":3000000,"layers":[{"clipId":"clip_2","opacity":1.0}]},
      {"timeUs":500000,"layers":[{"clipId":"clip_2","opacity":0.25}]}
    ]
  }
}
